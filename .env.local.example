# 1) Gemini key (required) — get it free at https://aistudio.google.com
#    Click "Get API key" -> "Create API key"
GEMINI_API_KEY=paste_your_gemini_key_here

# 2) TMDB key (required for movie poster thumbnails) — get it free at
#    https://www.themoviedb.org/settings/api  (sign up -> Settings -> API -> Create)
#    Use the "API Key (v3 auth)" value, NOT the "API Read Access Token".
TMDB_API_KEY=paste_your_tmdb_key_here

# 3) Your live site URL (optional but recommended once deployed) — used for
#    Google indexing (sitemap.xml, robots.txt) and social preview cards.
#    Example: https://cinefinder-yourname.vercel.app
NEXT_PUBLIC_SITE_URL=paste_your_live_url_here

# Never commit your real .env.local file — it's already in .gitignore.
